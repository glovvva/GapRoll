# PayCompass Pro - Konfiguracja Supabase
# Skopiuj ten plik jako secrets.toml i uzupełnij wartości
#
# NIE COMMITUJ secrets.toml do repozytorium!

[supabase]
# URL projektu Supabase (z dashboardu: Settings > API)
url = "https://your-project-id.supabase.co"

# Klucz publiczny (anon key) - używany przez frontend
key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."

# Klucz service_role (opcjonalny) - tylko dla operacji admin
# UWAGA: Nigdy nie udostępniaj tego klucza publicznie!
service_role_key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."

[openai]
# Klucz API OpenAI (opcjonalny - można też podać w UI)
api_key = "sk-..."
